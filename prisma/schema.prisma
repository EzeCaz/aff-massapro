generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Affiliate {
  id               String   @id @default(cuid())
  affid            String   @unique
  name             String
  email            String   @unique
  phone            String?
  password         String   @default("changeme")
  company          String?
  isActive         Boolean  @default(false)
  isApproved       Boolean  @default(false)
  commissionType   String   @default("standard")  // "standard", "premium", "custom"
  customSignupComm Float?                          // Override $100 signup commission
  customEnterprise Float?                          // Override $100/mo Enterprise
  customProfess    Float?                          // Override $50/mo Professional
  customBasic      Float?                          // Override $10/mo Basic
  notes            String?
  totalTraffic     Int      @default(0)
  totalConversions Int      @default(0)
  totalEarnings    Float    @default(0)
  approvedBalance  Float    @default(0)
  paidBalance      Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  clicks           Click[]
  referrals        Referral[]
  payouts          Payout[]
  ledgerEntries    CommissionLedger[]
  applications     AffiliateApplication[]
  events           AffiliateEvent[]
  purchases        PurchaseEvent[]

  @@index([affid])
  @@index([email])
  @@index([isActive])
  @@index([isApproved])
}

model AffiliateApplication {
  id             String   @id @default(cuid())
  name           String
  email          String
  phone          String?
  company        String?
  website        String?
  message        String?
  status         String   @default("pending")  // "pending", "approved", "rejected"
  reviewedAt     DateTime?
  reviewedBy     String?
  reviewNotes    String?
  generatedAffid String?
  createdAt      DateTime @default(now())
  affiliate      Affiliate? @relation(fields: [affiliateId], references: [id])
  affiliateId    String?

  @@index([status])
  @@index([email])
}

model Click {
  id          String   @id @default(cuid())
  affiliateId String
  affid       String
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
  pageUrl     String?
  eventType   String   @default("pageview")  // "pageview", "button_click"
  eventId     String?                          // e.g. "btn_hero_demo", "btn_pricing_tier"
  sessionId   String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id])

  @@index([affiliateId])
  @@index([affid])
  @@index([createdAt])
  @@index([eventType])
  @@index([eventId])
}

model Referral {
  id                String   @id @default(cuid())
  affiliateId       String
  affid             String
  leadName          String
  leadEmail         String?
  leadPhone         String?
  leadCompany       String?
  planType          String   // "Enterprise", "Professional", "Basic"
  leadStatus        String   // "Lead", "Attendee", "No Show", "Test", "Won", "Lost"
  signupCommission  Float    @default(0)
  monthlyCommission Float    @default(0)
  monthsActive      Int      @default(0)
  totalCommission   Float    @default(0)
  // First-Touch UTMs
  ftUtmSource       String?
  ftUtmMedium       String?
  ftUtmCampaign     String?
  ftUtmContent      String?
  ftUtmTerm         String?
  // Last-Touch UTMs
  ltUtmSource       String?
  ltUtmMedium       String?
  ltUtmCampaign     String?
  ltUtmContent      String?
  ltUtmTerm         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  affiliate         Affiliate @relation(fields: [affiliateId], references: [id])
  ledgerEntries     CommissionLedger[]

  @@index([affiliateId])
  @@index([affid])
  @@index([leadStatus])
  @@index([leadEmail])
  @@index([createdAt])
}

model Payout {
  id          String   @id @default(cuid())
  affiliateId String
  affid       String
  amount      Float
  status      String   @default("pending") // "pending", "approved", "processed"
  periodStart DateTime
  periodEnd   DateTime
  processedAt DateTime?
  createdAt   DateTime @default(now())
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id])

  @@index([affiliateId])
  @@index([status])
}

model CommissionLedger {
  id          String   @id @default(cuid())
  affiliateId String
  affid       String
  referralId  String
  type        String   // "signup", "recurring", "adjustment"
  amount      Float
  description String?
  monthNumber Int?     // For recurring: which month (1-12)
  createdAt   DateTime @default(now())
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id])
  referral    Referral  @relation(fields: [referralId], references: [id])

  @@index([affiliateId])
  @@index([affid])
  @@index([type])
  @@index([createdAt])
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hashed
  name      String
  role      String   @default("admin")  // "admin", "super_admin"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
}

model AffiliateEvent {
  id          String   @id @default(cuid())
  eventName   String
  affid       String?
  utmCampaign String?
  pageUrl     String?
  createdAt   DateTime @default(now())

  affiliate   Affiliate? @relation(fields: [affid], references: [affid])

  @@index([affid])
  @@index([eventName])
  @@index([createdAt])
}

model PurchaseEvent {
  id              String   @id @default(cuid())
  affiliateId     String?
  affid           String?
  eventType       String   // "add_to_cart", "purchase", "funnel_step"
  orderId         String?
  revenue         Float    @default(0)
  currency        String   @default("USD")
  planType        String?
  quantity        Int      @default(1)
  cartValue       Float    @default(0)
  customerEmail   String?
  customerName    String?
  sessionId       String?
  // First-Touch UTMs
  ftUtmSource     String?
  ftUtmMedium     String?
  ftUtmCampaign   String?
  ftUtmContent    String?
  ftUtmTerm       String?
  // Last-Touch UTMs
  ltUtmSource     String?
  ltUtmMedium     String?
  ltUtmCampaign   String?
  ltUtmContent    String?
  ltUtmTerm       String?
  pageUrl         String?
  funnelSteps     String?  // JSON array of funnel step names
  createdAt       DateTime @default(now())

  affiliate       Affiliate? @relation(fields: [affiliateId], references: [id])

  @@index([affiliateId])
  @@index([affid])
  @@index([eventType])
  @@index([planType])
  @@index([createdAt])
}
